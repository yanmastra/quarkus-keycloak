# ============================================================
# Keycloak + PostgreSQL + Nginx - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Domain & SSL ---
DOMAIN=auth.example.com
# Set to 'letsencrypt' or 'selfsigned'
SSL_MODE=selfsigned

# --- Keycloak Admin ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMe_Admin123!

# --- Keycloak Database ---
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=ChangeMe_DB123!
KC_DB_NAME=keycloak

# --- Realm Bootstrap ---
# Name of the realm JSON file inside keycloak/import/ (without .json)
REALM_IMPORT_FILE=realm-export

# --- Realm Configuration ---
KC_REALM_NAME=my-realm
KC_REALM_DISPLAY_NAME="My Application"
KC_WEB_APP_REDIRECT_URI=app.example.com
KC_BACKEND_CLIENT_SECRET=REPLACE_WITH_STRONG_M2M_SECRET
KC_SMTP_FROM=no-reply@example.com

# --- Paths (volumes on host) ---
# These are absolute paths on the VM where data is persisted
POSTGRES_DATA_PATH=./data/postgres
KEYCLOAK_DATA_PATH=./data/keycloak-data
NGINX_SSL_PATH=./nginx/ssl
